---
import Base from '../layouts/Base.astro';
import { SITE_URL } from '../lib/config';

const canonical = `${SITE_URL}/privacy/`;
const lastUpdated = '2026-07-07';
const contactEmail = 'info@free4me.nl';
---
<Base
  title="Privacy - VriendenLoterij Deals"
  description="Privacyverklaring van VriendenLoterij Deals."
  canonical={canonical}
  ogType="article"
>
  <main id="main" class="container" style="max-width:760px;padding:2rem 1rem 4rem;">
    <p><a href={import.meta.env.BASE_URL}>← Terug naar overzicht</a></p>
    <h1>Privacy</h1>
    <p><small>Laatst bijgewerkt: {lastUpdated}</small></p>
    <p>
      VriendenLoterij Deals is een statische GitHub Pages-site. We hebben geen accounts, formulieren,
      eigen cookies, tracking of analytics.
    </p>
    <h2>Externe diensten</h2>
    <ul>
      <li><strong>GitHub Pages</strong> host de statische site en kan technische serverlogs verwerken.</li>
      <li><strong>OpenStreetMap</strong> en <strong>Leaflet</strong> worden geladen wanneer je de kaart opent.</li>
      <li><strong>Google Fonts</strong> levert het Inter-lettertype.</li>
    </ul>
    <h2>Bronlinks</h2>
    <p>
      Links naar vriendenloterij.nl brengen je naar de bronwebsite. Vanaf dat moment geldt het privacybeleid
      van VriendenLoterij.
    </p>
    <h2>Contact</h2>
    <p>Vragen? Mail <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.</p>
  </main>
</Base>
