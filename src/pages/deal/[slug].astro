---
import Base from '../../layouts/Base.astro';
import { getAllDealDetails, formatDateTime } from '../../lib/deals';
import type { DealDetail } from '../../lib/deals';
import { SITE_URL } from '../../lib/config';

export async function getStaticPaths() {
  return getAllDealDetails()
    .filter(d => d.slug)
    .map(d => ({ params: { slug: d.slug }, props: { deal: d } }));
}

interface Props { deal: DealDetail; }
const { deal } = Astro.props;

const site = SITE_URL;
const canonical = `${site}/deal/${deal.slug}/`;
const pageTitle = `${deal.name} | VriendenLoterij Deals`;
const metaDesc = [
  deal.label,
  deal.location ? `in ${deal.location}` : '',
  deal.provider ? `bij ${deal.provider}` : '',
  deal.end_date ? `geldig tot ${deal.end_date}` : '',
].filter(Boolean).join(' ');

const h = deal.history;
const changeLog = (deal.changeLog || []).filter(c => c.fields?.length);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: deal.name,
  url: canonical,
  description: deal.description,
  image: deal.image_url,
  startDate: deal.start_date || undefined,
  endDate: deal.end_date || undefined,
  location: deal.locations?.[0] ? {
    '@type': 'Place',
    name: deal.provider || deal.locations[0].name,
    address: deal.address || deal.locations[0].address,
    geo: deal.locations[0].lat != null && deal.locations[0].lng != null ? {
      '@type': 'GeoCoordinates',
      latitude: deal.locations[0].lat,
      longitude: deal.locations[0].lng,
    } : undefined,
  } : undefined,
};
---
<Base
  title={pageTitle}
  description={metaDesc || deal.description}
  canonical={canonical}
  ogType="article"
  ogImage={deal.image_url}
  ogImageAlt={deal.name}
  noindex={!deal.isActive}
  jsonLd={jsonLd}
  needsLeaflet={deal.locations.length > 0}
>
  <div class="deal-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Broodkruimelpad">
        <a href={import.meta.env.BASE_URL}>VriendenLoterij Deals</a>
        <span aria-hidden="true">›</span>
        <span>{deal.name}</span>
      </nav>
      <h1>{deal.name}</h1>
      <div class="deal-hero-meta">
        {deal.label && <span>{deal.label}</span>}
        {deal.location && <span>🗺️ {deal.location}</span>}
        {deal.provider && <span>📍 {deal.provider}</span>}
        {deal.locations.length > 1 && <span>📌 {deal.locations.length} locaties</span>}
        {deal.isActive ? <span class="status-active">Actief</span> : <span class="status-inactive">Niet meer actief</span>}
      </div>
    </div>
  </div>

  <main id="main" class="container">
    <a href={import.meta.env.BASE_URL} class="back-link" style="margin-top:1.25rem;display:inline-flex;">← Terug naar overzicht</a>

    <div class="deal-grid">
      <div>
        <div class="card" style="margin-bottom:1rem">
          <h2>Aanbieding</h2>
          {deal.image_url && <img src={deal.image_url} alt="" loading="lazy" style="width:100%;border-radius:12px;margin-bottom:1rem;" />}
          {deal.label && <p><span class="discount-badge">{deal.label}</span></p>}
          {deal.description && <p>{deal.description}</p>}
          {deal.isActive && (
            <a href={deal.url} target="_blank" rel="noopener noreferrer" class="cta-btn">
              Bekijk bij VriendenLoterij ↗
            </a>
          )}
        </div>

        <div class="card">
          <h2>Details</h2>
          <dl class="kv-list">
            {deal.provider && <><dt>Locatie</dt><dd>{deal.provider}</dd></>}
            {deal.location && <><dt>Plaats</dt><dd>{deal.location}</dd></>}
            {deal.start_date && <><dt>Start</dt><dd>{formatDateTime(deal.start_date)}</dd></>}
            {deal.end_date && <><dt>Einde</dt><dd>{formatDateTime(deal.end_date)}</dd></>}
            {deal.categories?.length ? <><dt>Categorieen</dt><dd>{deal.categories.join(', ')}</dd></> : null}
            {deal.types?.length ? <><dt>Tags</dt><dd>{deal.types.join(', ')}</dd></> : null}
            {h && <><dt>Eerste gezien</dt><dd>{h.first_seen}</dd></>}
            {h && <><dt>Laatste gezien</dt><dd>{h.last_seen}</dd></>}
            {h && <><dt>Wijzigingen</dt><dd>{h.change_count}</dd></>}
          </dl>
        </div>
      </div>

      <div>
        {changeLog.length > 0 && (
          <div class="card" style="margin-bottom:1rem">
            <h2>Wijzigingshistorie</h2>
            <div style="overflow-x:auto">
              <table class="price-log-table">
                <thead>
                  <tr>
                    <th>Datum</th>
                    <th>Velden</th>
                  </tr>
                </thead>
                <tbody>
                  {changeLog.map(change => (
                    <tr>
                      <td>{change.date}</td>
                      <td>{change.fields.join(', ')}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {deal.locations.length > 0 && (
          <div class="card">
            <h2>Kaart</h2>
            <div id="detail-map" style="height:360px;border-radius:12px;overflow:hidden"></div>
          </div>
        )}
      </div>
    </div>

    {deal.locations.length > 1 && (
      <section class="card" style="margin-top:1rem">
        <h2>Alle locaties</h2>
        <ul>
          {deal.locations.map(loc => (
            <li>{[loc.name, loc.address, loc.city].filter(Boolean).join(' - ')}</li>
          ))}
        </ul>
      </section>
    )}
  </main>

  {deal.locations.length > 0 && (
    <script define:vars={{ locations: deal.locations }}>
      window.addEventListener('DOMContentLoaded', () => {
        const script = document.createElement('script');
        script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
        script.crossOrigin = 'anonymous';
        script.onload = () => {
          const points = locations.filter((l) => l.lat != null && l.lng != null);
          if (!points.length) return;
          const map = window.L.map('detail-map').setView([points[0].lat, points[0].lng], 10);
          window.L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap contributors' }).addTo(map);
          const markers = points.map((loc) => window.L.marker([loc.lat, loc.lng]).addTo(map).bindPopup([loc.name, loc.address, loc.city].filter(Boolean).join('<br>')));
          if (markers.length > 1) map.fitBounds(window.L.latLngBounds(markers.map(m => m.getLatLng())), { padding: [30, 30] });
        };
        document.head.appendChild(script);
      });
    </script>
  )}
</Base>
