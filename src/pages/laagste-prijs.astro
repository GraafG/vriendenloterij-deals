---
import Base from '../layouts/Base.astro';
import { SITE_URL } from '../lib/config';
import { getAllDealDetails } from '../lib/deals';
import { isWinactie } from '../lib/categorize';

const canonical = `${SITE_URL}/laagste-prijs/`;
const deals = getAllDealDetails()
  .filter(isWinactie)
  .sort((a, b) => (a.end_ts ?? 0) - (b.end_ts ?? 0))
  .slice(0, 100);
const base = import.meta.env.BASE_URL;
---
<Base
  title="Winacties - VriendenLoterij Deals"
  description="Actieve VriendenLoterij VIP-KAART winacties, gesorteerd op einddatum."
  canonical={canonical}
  ogType="website"
>
  <main id="main" class="container" style="max-width:960px;padding:2rem 1rem 4rem;">
    <p><a href={base}>← Terug naar overzicht</a></p>
    <h1>Winacties</h1>
    <p class="lead">Actieve winacties en kans-op acties. Deze categorie wordt extra vaak gecontroleerd voor new-wiki notificaties.</p>
    {deals.length === 0 ? (
      <p><em>Geen actieve winacties gevonden.</em></p>
    ) : (
      <ul class="deal-card-list" style="list-style:none;padding:0;">
        {deals.map(d => (
          <li style="margin-bottom:1.25rem;padding:1rem;border:1px solid #e5e7eb;border-radius:8px;">
            <a href={`${base}deal/${d.slug}/`} style="font-weight:600;font-size:1.05rem;">{d.name}</a>
            <p style="margin:0.25rem 0;color:#6b7280;font-size:0.9rem;">{[d.location, d.provider].filter(Boolean).join(' · ')}</p>
            <p style="margin:0.5rem 0 0;font-size:0.95rem;">{d.label || 'Winactie'} {d.end_date && <span>· t/m {d.end_date}</span>}</p>
          </li>
        ))}
      </ul>
    )}
  </main>
</Base>
