---
import Base from '../layouts/Base.astro';
import { SITE_URL } from '../lib/config';
import { getAllDealDetails } from '../lib/deals';
import { isChangedOffer, lastChangeDate } from '../lib/categorize';

const canonical = `${SITE_URL}/prijsdalingen/`;
const deals = getAllDealDetails()
  .filter(isChangedOffer)
  .sort((a, b) => lastChangeDate(b).localeCompare(lastChangeDate(a)))
  .slice(0, 80);
const base = import.meta.env.BASE_URL;
---
<Base
  title="Gewijzigde aanbiedingen - VriendenLoterij Deals"
  description="VIP-KAART aanbiedingen waarvan inhoud, datum, categorie, locatie of status recent wijzigde."
  canonical={canonical}
  ogType="website"
>
  <main id="main" class="container" style="max-width:960px;padding:2rem 1rem 4rem;">
    <p><a href={base}>← Terug naar overzicht</a></p>
    <h1>Gewijzigde aanbiedingen</h1>
    <p class="lead">Niet alleen prijzen: deze lijst volgt alle relevante wijzigingen in de VriendenLoterij VIP-KAART dataset.</p>
    {deals.length === 0 ? (
      <p><em>Geen gewijzigde actieve aanbiedingen in de laatste snapshot.</em></p>
    ) : (
      <ul class="deal-card-list" style="list-style:none;padding:0;">
        {deals.map(d => (
          <li style="margin-bottom:1.25rem;padding:1rem;border:1px solid #e5e7eb;border-radius:8px;">
            <a href={`${base}deal/${d.slug}/`} style="font-weight:600;font-size:1.05rem;">{d.name}</a>
            <p style="margin:0.25rem 0;color:#6b7280;font-size:0.9rem;">{[d.label, d.location, d.provider].filter(Boolean).join(' · ')}</p>
            <p style="margin:0.5rem 0 0;font-size:0.95rem;">Laatste wijziging: {lastChangeDate(d) || d.history?.last_seen}</p>
          </li>
        ))}
      </ul>
    )}
  </main>
</Base>
