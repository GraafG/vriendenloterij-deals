---
import Base from '../layouts/Base.astro';
import { SITE_URL, SOURCE_SITE_URL } from '../lib/config';
import { getAllDealDetails } from '../lib/deals';
import dealsAppUrl from '../scripts/deals-app.ts?url';

const site = SITE_URL;
const canonical = site + '/';
const description = 'Alle VriendenLoterij VIP-KAART aanbiedingen, winacties, gratis uitjes en kortingen op een kaart met wijzigingshistorie.';
const baseUrl = import.meta.env.BASE_URL;

const activeDeals = getAllDealDetails()
  .filter(d => d.isActive && d.slug)
  .sort((a, b) => Number(b.is_winactie) - Number(a.is_winactie) || (a.end_ts ?? 0) - (b.end_ts ?? 0));

const newWinacties = activeDeals
  .filter(d => d.is_winactie)
  .slice(0, 6);

const homepageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VriendenLoterij Deals',
  url: site + '/',
  description,
};
---
<Base
  title="VriendenLoterij Deals - VIP-KAART aanbiedingen"
  description={description}
  canonical={canonical}
  ogImageAlt="VriendenLoterij Deals - VIP-KAART aanbiedingen"
  jsonLd={homepageJsonLd}
  needsLeaflet
>
  <header class="hero">
    <div class="container hero-inner">
      <div class="hero-top">
        <div class="brand">
          <div class="brand-mark" aria-hidden="true">★</div>
          <div>
            <h1>VriendenLoterij Deals</h1>
            <p>VIP-KAART aanbiedingen, winacties en gratis uitjes</p>
          </div>
        </div>
        <a href={SOURCE_SITE_URL} target="_blank" rel="noopener noreferrer" class="sister-link">
          Bron bekijken <span aria-hidden="true">↗</span>
        </a>
      </div>

      <p class="hero-tagline">
        Volg <span class="accent">winacties, gratis toegang en kortingen</span> met kaartweergave en wijzigingshistorie.
      </p>

      <div class="filter-bar" role="search">
        <select id="date-picker" title="Selecteer datum" aria-label="Selecteer datum"></select>
        <select id="location-filter" title="Filter op plaats" aria-label="Filter op plaats"><option value="">Alle plaatsen</option></select>
        <input type="text" id="search-box" placeholder="Zoek op naam, plaats, categorie..." aria-label="Zoek aanbiedingen" />
        <select id="type-filter" title="Filter op type" aria-label="Filter op type">
          <option value="">Alle types</option>
          <option value="winactie">Winacties</option>
          <option value="gratis">Gratis</option>
          <option value="korting">Korting</option>
        </select>
        <select id="status-filter" title="Filter op status" aria-label="Filter op status">
          <option value="active">Actief</option>
          <option value="all">Alles</option>
          <option value="expired">Niet meer actief</option>
        </select>
      </div>
    </div>
  </header>

  <main id="main" class="container stats-section">
    <div class="stats-bar" id="stats-bar"></div>
  </main>

  {newWinacties.length > 0 && (
    <section class="container recent-drops-section" aria-labelledby="winacties-title">
      <div class="section-heading">
        <div>
          <h2 id="winacties-title">Nieuwste winacties</h2>
          <p>De winactie-watcher controleert deze categorie extra vaak.</p>
        </div>
      </div>
      <div class="recent-drops-grid">
        {newWinacties.map(d => (
          <article class="drop-card">
            <div class="drop-card-main">
              <a href={`${baseUrl}deal/${d.slug}/`} class="drop-card-title">{d.name}</a>
              <span class="drop-card-meta">{[d.location, d.provider].filter(Boolean).join(' · ')}</span>
            </div>
            <div class="drop-card-price">
              <span class="drop-amount">{d.label || 'Winactie'}</span>
            </div>
            <div class="drop-card-footer">
              <span>{d.end_date ? `t/m ${d.end_date}` : 'Geen einddatum bekend'}</span>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="container">
    <div class="view-toggle" role="tablist" aria-label="Weergave kiezen">
      <button id="btn-table" class="active" data-view="table" role="tab" aria-selected="true">Tabel</button>
      <button id="btn-map" data-view="map" role="tab" aria-selected="false">Kaart</button>
      <button id="btn-split" data-view="split" role="tab" aria-selected="false">Kaart + Lijst</button>
    </div>

    <div class="split-wrap">
      <div id="map-container"></div>
      <div id="table-container">
        <div class="table-wrap">
          <div class="loading" id="loading">Aanbiedingen laden...</div>
          <div class="table-scroll">
            <table id="deals-table">
              <thead>
                <tr>
                  <th data-col="name">Aanbieding <span class="arrow"></span></th>
                  <th data-col="kind">Type <span class="arrow"></span></th>
                  <th data-col="location">Plaats <span class="arrow"></span></th>
                  <th data-col="provider" class="col-extra">Locatie <span class="arrow"></span></th>
                  <th data-col="end_ts">Geldig tot <span class="arrow"></span></th>
                  <th class="col-extra">Categorie</th>
                  <th class="col-extra">Status</th>
                </tr>
              </thead>
              <tbody id="deals-body">
                {activeDeals.map(d => (
                  <tr>
                    <td><a href={`${baseUrl}deal/${d.slug}/`}>{d.name}</a></td>
                    <td><span class="discount-badge">{d.label || (d.is_winactie ? 'Winactie' : 'Aanbod')}</span></td>
                    <td>{d.location}</td>
                    <td class="col-extra">{d.provider}</td>
                    <td>{d.end_date || ''}</td>
                    <td class="col-extra">{(d.categories || []).slice(0, 2).join(', ')}</td>
                    <td class="col-extra">{d.history?.trend === 'new' ? 'Nieuw' : d.history?.trend === 'changed' ? 'Gewijzigd' : 'Stabiel'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="module" src={dealsAppUrl}></script>
</Base>
