---
import Base from '../layouts/Base.astro';
import { SITE_URL } from '../lib/config';
import { getAllDealDetails } from '../lib/deals';
import { isDiscountOffer } from '../lib/categorize';

const canonical = `${SITE_URL}/hotels/`;
const deals = getAllDealDetails()
  .filter(isDiscountOffer)
  .sort((a, b) => (a.end_ts ?? 0) - (b.end_ts ?? 0));
const base = import.meta.env.BASE_URL;
---
<Base
  title="Kortingen - VriendenLoterij Deals"
  description="Actieve VIP-KAART aanbiedingen met korting."
  canonical={canonical}
  ogType="website"
>
  <main id="main" class="container" style="max-width:960px;padding:2rem 1rem 4rem;">
    <p><a href={base}>← Terug naar overzicht</a></p>
    <h1>Kortingen</h1>
    <p class="lead">Actieve aanbiedingen met korting, gesorteerd op einddatum.</p>
    {deals.length === 0 ? (
      <p><em>Geen actieve kortingen gevonden.</em></p>
    ) : (
      <ul class="deal-card-list" style="list-style:none;padding:0;">
        {deals.map(d => (
          <li style="margin-bottom:1.25rem;padding:1rem;border:1px solid #e5e7eb;border-radius:8px;">
            <a href={`${base}deal/${d.slug}/`} style="font-weight:600;font-size:1.05rem;">{d.name}</a>
            <p style="margin:0.25rem 0;color:#6b7280;font-size:0.9rem;">{[d.label, d.location, d.provider].filter(Boolean).join(' · ')}</p>
          </li>
        ))}
      </ul>
    )}
  </main>
</Base>
