---
import '../styles/global.css';
import { SITE_URL } from '../lib/config';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
  needsLeaflet?: boolean;
}

const { title, description, canonical, ogType = 'website', ogImage, ogImageAlt, jsonLd, noindex = false, needsLeaflet = false } = Astro.props;
const ogImageUrl = ogImage ?? `${SITE_URL}/og-default.png`;
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="site-base" content={import.meta.env.BASE_URL} />
  <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
  <title>{title}</title>
  {noindex && <meta name="robots" content="noindex,follow" />}
  {description && <meta name="description" content={description} />}
  {canonical && <link rel="canonical" href={canonical} />}
  {canonical && <link rel="alternate" hreflang="nl" href={canonical} />}
  {canonical && <link rel="alternate" hreflang="x-default" href={canonical} />}
  <link rel="alternate" type="application/rss+xml" title="VriendenLoterij Deals" href={`${SITE_URL}/feed.xml`} />
  <link rel="search" type="application/opensearchdescription+xml" title="VriendenLoterij Deals" href={`${SITE_URL}/opensearch.xml`} />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:site_name" content="VriendenLoterij Deals" />
  <meta property="og:locale" content="nl_NL" />
  {description && <meta property="og:description" content={description} />}
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImageUrl} />
  {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  {needsLeaflet && (
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="anonymous"
    />
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <a href="#main" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Skip naar hoofdinhoud</a>
  <slot />
</body>
</html>
